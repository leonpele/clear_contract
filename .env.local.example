OPENAI_API_KEY=your_openai_api_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Stripe Price IDs (price_…), not Product IDs (prod_…). Server-only: no rebuild needed on Vercel when you change them.
STRIPE_PRICE_ONETIME=price_xxx
STRIPE_PRICE_SUBSCRIPTION=price_xxx

# Optional legacy names (still read by checkout if the STRIPE_* vars above are unset)
# NEXT_PUBLIC_STRIPE_PRICE_ONETIME=price_xxx
# NEXT_PUBLIC_STRIPE_PRICE_SUBSCRIPTION=price_xxx

NEXT_PUBLIC_APP_URL=http://localhost:3000
