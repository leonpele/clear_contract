OPENAI_API_KEY=your_openai_api_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Stripe Price IDs (price_…), not Product IDs (prod_…). Server-only: no rebuild needed on Vercel when you change them.
# ONETIME = one-time payment in Stripe (mode payment). SUBSCRIPTION = recurring/monthly (mode subscription).
STRIPE_PRICE_ONETIME=price_xxx_one_time
STRIPE_PRICE_SUBSCRIPTION=price_xxx_recurring_monthly

# Optional: same as above but NEXT_PUBLIC_* also works. Or paste IDs in lib/stripePriceIds.ts.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Auth + profiles)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
